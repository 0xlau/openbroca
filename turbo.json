{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": ["out/**", "dist/**"]
    },
    "bundle:mac": {
      "outputs": ["out/**", "dist/**"]
    },
    "bundle:win": {
      "outputs": ["out/**", "dist/**"]
    },
    "bundle:linux": {
      "outputs": ["out/**", "dist/**"]
    },
    "bundle:unpack": {
      "outputs": ["out/**", "dist/**"]
    },
    "typecheck": {},
    "test": {},
    "lint": {},
    "format": {
      "cache": false
    }
  }
}
